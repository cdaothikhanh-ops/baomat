@model QLDH.Models.NhanVien

@{
    ViewData["Title"] = "Thêm nhân viên";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH + Xin chào -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Bên phải: nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>


<div class="container-fluid" style="margin-top:70px;">
    <h2 class="text-primary mb-3">Thêm Nhân viên</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="MANV" class="form-label">Mã nhân viên</label>
            <input asp-for="MANV" class="form-control" readonly />
            <span asp-validation-for="MANV" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TENNV" class="form-label">Tên nhân viên</label>
            <input asp-for="TENNV" class="form-control" placeholder="Tên nhân viên" />
            <span asp-validation-for="TENNV" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CHUCVU" class="form-label">Chức vụ</label>
            <select asp-for="CHUCVU" class="form-select">
                <option value="">-- Chọn chức vụ --</option>
                <option value="Bán hàng">Bán hàng</option>
                <option value="Kho hàng">Kho hàng</option>
            </select>
            <span asp-validation-for="CHUCVU" class="text-danger"></span>
        </div>


        <div class="mb-3">
            <label asp-for="DIACHI" class="form-label">Địa chỉ</label>
            <input asp-for="DIACHI" class="form-control" placeholder="Địa chỉ" />
            <span asp-validation-for="DIACHI" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SDT" class="form-label">SĐT</label>
            <input asp-for="SDT" class="form-control" placeholder="Số điện thoại" />
            <span asp-validation-for="SDT" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EMAIL" class="form-label">Email</label>
            <input asp-for="EMAIL" class="form-control" placeholder="Email" />
            <span asp-validation-for="EMAIL" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-action="IndexNV" class="btn btn-secondary">Hủy</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
