@model QLDH.Models.NhanVien

@{
    ViewData["Title"] = "Cập nhật thông tin Nhân viên";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Logo QLDH -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>

<div class="container-fluid" style="margin-top:70px;">
    <h2 class="text-primary mb-3">Cập nhật thông tin Nhân viên</h2>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="MANV" />

        <div class="mb-3">
            <label asp-for="TENNV" class="form-label">Tên nhân viên</label>
            <input asp-for="TENNV" class="form-control" />
            <span asp-validation-for="TENNV" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CHUCVU" class="form-label">Chức vụ</label>
            <select asp-for="CHUCVU" class="form-select">
                <option value="">-- Chọn chức vụ --</option>
                <option value="Bán hàng" selected="@Model.CHUCVU == " Bán hàng"">Bán hàng</option>
                <option value="Kho hàng" selected="@Model.CHUCVU == " Kho hàng"">Kho hàng</option>
            </select>
            <span asp-validation-for="CHUCVU" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DIACHI" class="form-label">Địa chỉ</label>
            <input asp-for="DIACHI" class="form-control" />
            <span asp-validation-for="DIACHI" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SDT" class="form-label">SĐT</label>
            <input asp-for="SDT" class="form-control" />
            <span asp-validation-for="SDT" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EMAIL" class="form-label">Email</label>
            <input asp-for="EMAIL" class="form-control" />
            <span asp-validation-for="EMAIL" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-action="IndexNV" class="btn btn-secondary">Hủy</a>
    </form>
</div>

<!-- Modal xác nhận đăng xuất -->
<div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="logoutModalLabel">Xác nhận</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                Bạn có muốn đăng xuất?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                <a href="/Account/Logout" class="btn btn-danger">Đăng xuất</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
