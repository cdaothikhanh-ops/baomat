@model IEnumerable<QLDH.Models.NhaCungCap>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@{
    ViewData["Title"] = "Danh sách nhà cung cấp";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>

<!-- Nội dung chính -->
<div style="margin-top:70px; padding:16px;">
    <!-- ✅ tránh bị topbar đè -->
    <h2 class="text-dark mb-3">Danh sách nhà cung cấp</h2>

    <p>
        <a asp-action="Create" class="btn btn-primary">+ Thêm mới</a>
    </p>

    <table class="table table-bordered table-hover mt-3">
        <thead class="table-light">
            <tr>
                <th>Mã NCC</th>
                <th>Tên NCC</th>
                <th>Địa chỉ</th>
                <th>SĐT</th>
                <th>Email</th>
                <th>Chức năng</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ncc in Model)
            {
                <tr>
                    <td>@ncc.MANCC</td>
                    <td>@ncc.TENNCC</td>
                    <td>@ncc.DIACHI</td>
                    <td>@ncc.SDT</td>
                    <td>@ncc.EMAIL</td>
                    <td>
                        <!-- Edit -->
                        <a asp-action="Edit" asp-route-id="@ncc.MANCC" class="btn btn-sm btn-primary text-white">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        <!-- Delete -->
                        <button class="btn btn-sm btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@ncc.MANCC"
                                data-name="@ncc.TENNCC"
                                title="Xoá">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>

                </tr>
            }
        </tbody>
    </table>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Xác nhận xoá</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    Bạn có chắc muốn xoá nhà cung cấp <strong id="nccName"></strong>?
                </div>
                <div class="modal-footer">
                    <form id="deleteForm" method="post" asp-action="Delete" asp-controller="NhaCungCap">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="MANCC" id="nccId" value="" />
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger">Xoá</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal xác nhận đăng xuất -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="logoutModalLabel">Xác nhận</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    Bạn có muốn đăng xuất?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                    <a href="/Account/Logout" class="btn btn-danger">Đăng xuất</a>
                </div>
            </div>
        </div>
    </div>

</div>
@section Scripts {
    <script>
        var deleteModal = document.getElementById('deleteModal');
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget; // nút vừa click
            var id = button.getAttribute('data-id');
            var name = button.getAttribute('data-name');

            deleteModal.querySelector('#nccName').textContent = name;
            deleteModal.querySelector('#nccId').value = id;
        });
    </script>
}