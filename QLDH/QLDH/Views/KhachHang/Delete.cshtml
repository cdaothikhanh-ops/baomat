@model QLDH.Models.KhachHang
@{
    ViewData["Title"] = "Xóa khách hàng";
}

<h2>Xóa khách hàng</h2>
<hr />

<p>Bạn có chắc chắn muốn xóa khách hàng <strong>@Model.TENKH</strong> (Mã KH: @Model.MAKH)?</p>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="MAKH" />

    <button type="submit" class="btn btn-danger me-2">
        <i class="bi bi-trash"></i> Xóa
    </button>
    <a asp-action="IndexKH" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</form>
