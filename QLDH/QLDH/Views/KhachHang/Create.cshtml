@model QLDH.Models.KhachHang

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@{
    ViewData["Title"] = "Thêm khách hàng";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH + Xin chào -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Bên phải: nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>


<div class="container" style="margin-top:60px;">
    <h3>Thêm khách hàng</h3>

    <form asp-action="Create" asp-controller="KhachHang" method="post" class="mt-3">
        @Html.AntiForgeryToken()

        <!-- Ẩn MAKH, do hệ thống sinh -->
        @Html.HiddenFor(model => model.MAKH)

        <!-- Xoá ValidationSummary để chỉ hiện lỗi dưới mỗi input -->
        <!-- <div asp-validation-summary="All" class="text-danger mb-2"></div> -->

        <div class="mb-3">
            <label asp-for="TENKH" class="form-label"></label>
            <input asp-for="TENKH" class="form-control" />
            <span asp-validation-for="TENKH" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DIACHI" class="form-label"></label>
            <input asp-for="DIACHI" class="form-control" />
            <span asp-validation-for="DIACHI" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SDT" class="form-label"></label>
            <input asp-for="SDT" class="form-control" />
            <span asp-validation-for="SDT" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="EMAIL" class="form-label"></label>
            <input asp-for="EMAIL" class="form-control" />
            <span asp-validation-for="EMAIL" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MALOAIKH" class="form-label">Loại khách hàng</label>
            <select asp-for="MALOAIKH" class="form-select">
                <option value="">-- Chọn loại khách hàng --</option>
                @if (ViewBag.LoaiKhachHang != null)
                {
                    foreach (var loai in ViewBag.LoaiKhachHang as List<QLDH.Models.LoaiKhachHang>)
                    {
                        <option value="@loai.MALOAIKH">@loai.TENLOAIKH</option>
                    }
                }
            </select>
            <span asp-validation-for="MALOAIKH" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-action="IndexKH" asp-controller="KhachHang" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

<!-- Modal xác nhận đăng xuất -->
<div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="logoutModalLabel">Xác nhận</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                Bạn có muốn đăng xuất?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                <a href="/Account/Logout" class="btn btn-danger">Đăng xuất</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
