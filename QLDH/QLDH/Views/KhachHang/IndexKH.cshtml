<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@model IEnumerable<QLDH.Models.KhachHang>
@{
    ViewData["Title"] = "Danh sách khách hàng";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}
<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH + Xin chào -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Bên phải: nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>


<div class="container-fluid" style="margin-top:70px;">
    <h2>Danh sách khách hàng</h2>

    <p>
        <a asp-action="Create" class="btn btn-primary">+ Thêm khách hàng</a>
    </p>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Mã khách hàng</th>
                <th>Tên khách hàng</th>
                <th>Địa chỉ</th>
                <th>Số điện thoại</th>
                <th>Email</th>
                <th>Mã loại khách hàng</th>
                <th>Chức năng</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MAKH</td>
                    <td>@item.TENKH</td>
                    <td>@item.DIACHI</td>
                    <td>@item.SDT</td>
                    <td>@item.EMAIL</td>
                    <td>@item.MALOAIKH</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.MAKH" class="btn btn-sm btn-primary text-white">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        <button class="btn btn-sm btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@(item.MAKH)"
                                data-name="@(item.TENKH)">
                            Xoá
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-action="DeleteConfirmed" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title" id="deleteModalLabel">Xác nhận xoá</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Bạn có chắc muốn xoá khách hàng <strong id="khName"></strong> không?</p>
                        <input type="hidden" name="id" id="khId" value="" />
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger">Xoá</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>

<!-- Modal xác nhận đăng xuất -->
<div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="logoutModalLabel">Xác nhận</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                Bạn có muốn đăng xuất?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                <a href="/Account/Logout" class="btn btn-danger">Đăng xuất</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var deleteModal = document.getElementById('deleteModal')
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget; // nút đã click
            var khId = button.getAttribute('data-id');
            var khName = button.getAttribute('data-name');

            var modalBodyName = deleteModal.querySelector('#khName');
            var modalInputId = deleteModal.querySelector('#khId');

            modalBodyName.textContent = khName;
            modalInputId.value = khId;
        });
    </script>
}
