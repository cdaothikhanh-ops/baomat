@model QLDH.Models.SanPham
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@{
    ViewData["Title"] = "Sửa sản phẩm";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}
<!-- 🔹 Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- 🔹 Bên phải: Đăng xuất -->
    <div class="ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>
<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-header text-black">
            <h4 class="mb-0"><i class="bi bi-pencil"></i> Sửa sản phẩm</h4>
        </div>

        <div class="card-body">
            <form asp-action="EditSP" method="post">
                <div class="mb-3">
                    <label class="form-label">Mã sản phẩm</label>
                    <input asp-for="MASP" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Tên sản phẩm</label>
                    <input asp-for="TENSP" class="form-control" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Giá nhập</label>
                        <input asp-for="GIANHAP" class="form-control" type="number" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Giá bán</label>
                        <input asp-for="GIABAN" class="form-control" type="number" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Số lượng tồn</label>
                    <input asp-for="SOLUONGTON" class="form-control" type="number" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Ghi chú</label>
                    <textarea asp-for="GHICHU" class="form-control" rows="3"></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="IndexSP" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-warning text-white">
                        <i class="bi bi-check-circle"></i> Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
