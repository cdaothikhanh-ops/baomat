@model QLDH.Models.ChangePassViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
    ViewData["ShowFooter"] = false;
}

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow-lg p-4" style="width: 380px; border-radius: 12px;">
        <h3 class="text-center text-primary mb-4">Đổi mật khẩu</h3>

        <form asp-action="ChangePass" method="post">
            <div class="mb-3">
                <input asp-for="Manv" class="form-control" placeholder="Mã nhân viên" />
                <span asp-validation-for="Manv" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="MatkhauMoi" class="form-control" type="password" placeholder="Mật khẩu mới" />
                <span asp-validation-for="MatkhauMoi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="NhapLaiMatkhauMoi" class="form-control" type="password" placeholder="Nhập lại mật khẩu mới" />
                <span asp-validation-for="NhapLaiMatkhauMoi" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 fw-semibold">
                Cập nhật mật khẩu
            </button>
        </form>

        <div class="text-center mt-3">
            <a asp-action="Login" class="text-decoration-none">Quay lại đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
