@model QLDH.Models.ChangePassViewModel
@using QLDH.Authorization
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
    
    var vaiTro = Context.Session.GetString("VaiTro") ?? "";
    var tenNV = Context.Session.GetString("TenNV") ?? "Người dùng";
    var maNV = Context.Session.GetString("MaNV") ?? "";
    
    bool isQuanLy = vaiTro == Roles.QuanLy;
    bool isBanHang = vaiTro == Roles.BanHang;
    bool isKhoHang = vaiTro == Roles.KhoHang;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH + Xin chào -->
    <div class="d-flex align-items-center">
        <strong class="me-2">QLDH</strong>
        <span class="ms-3">
            Xin chào, <strong>@tenNV</strong>
            <span class="badge @(isQuanLy ? "bg-success" : isBanHang ? "bg-warning text-dark" : "bg-info") ms-2">
                @vaiTro
            </span>
        </span>
    </div>

    <!-- Bên phải: nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">
            <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
        </a>
    </div>
</div>

<!-- Container chính -->
<div class="d-flex" style="height:calc(100vh - 50px); margin:0; padding:0;">
    <!-- Sidebar -->
    <nav style="width:70px; height:100vh; top:50px; left:0; position:fixed; background-color:white; border-right:1px solid #dee2e6; z-index:999;">
        <div class="d-flex flex-column align-items-center p-3">
            <a asp-controller="Account" asp-action="Dashboard" class="text-primary mb-3 text-center fs-4" title="Dashboard">
                <i class="bi bi-house-door-fill"></i>
            </a>
            @if (isQuanLy)
            {
                <a asp-controller="NhanVien" asp-action="IndexNV" class="text-dark mb-3 text-center fs-4" title="Nhân viên">
                    <i class="bi bi-people-fill"></i>
                </a>
            }
            @if (isQuanLy || isKhoHang)
            {
                <a asp-controller="SanPham" asp-action="IndexSP" class="text-dark mb-3 text-center fs-4" title="Sản phẩm">
                    <i class="bi bi-box-seam"></i>
                </a>
            }
            @if (isQuanLy || isBanHang)
            {
                <a asp-controller="DonHang" asp-action="IndexDH" class="text-dark mb-3 text-center fs-4" title="Đơn hàng">
                    <i class="bi bi-file-earmark-text"></i>
                </a>
            }
            @if (isQuanLy)
            {
                <a asp-controller="AuditLog" asp-action="Index" class="text-dark mb-3 text-center fs-4" title="Nhật ký hệ thống">
                    <i class="bi bi-journal-text"></i>
                </a>
            }
        </div>
    </nav>

    <!-- Nội dung chính -->
    <div class="flex-grow-1" style="min-height:100vh; width:calc(100% - 70px); margin-top:50px; padding:16px; margin-left:70px;">

        <!-- Thông báo -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Phần 0: Tài khoản -->
        <h5 class="mb-3"><i class="bi bi-person-circle me-2"></i>Tài khoản</h5>
        <div class="row g-3 mb-4">
            <!-- Đổi mật khẩu -->
            <div class="col-auto">
                <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;" 
                     data-bs-toggle="modal" data-bs-target="#changePassModal">
                    <i class="bi bi-key fs-2 text-warning"></i>
                    <div class="mt-2">Đổi mật khẩu</div>
                </div>
            </div>
            
            <!-- Thông tin cá nhân -->
            <div class="col-auto">
                <a asp-controller="NhanVien" asp-action="Edit" asp-route-id="@maNV" class="text-decoration-none text-dark">
                    <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                        <i class="bi bi-person-gear fs-2 text-info"></i>
                        <div class="mt-2">Thông tin cá nhân</div>
                    </div>
                </a>
            </div>

            <!-- Đăng xuất -->
            <div class="col-auto">
                <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;" 
                     data-bs-toggle="modal" data-bs-target="#logoutModal">
                    <i class="bi bi-box-arrow-right fs-2 text-danger"></i>
                    <div class="mt-2">Đăng xuất</div>
                </div>
            </div>
        </div>

        @if (isQuanLy)
        {
            <!-- Phần 1: Quản lý nhân viên (Chỉ Quản lý) -->
            <h5 class="mb-3"><i class="bi bi-people me-2"></i>Quản lý Nhân viên</h5>
            <div class="row g-3 mb-4">
                <div class="col-auto">
                    <a asp-controller="NhanVien" asp-action="IndexNV" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-person-badge fs-2 text-primary"></i>
                            <div class="mt-2">Danh sách NV</div>
                        </div>
                    </a>
                </div>
                <div class="col-auto">
                    <a asp-controller="NhanVien" asp-action="Create" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-person-plus fs-2 text-success"></i>
                            <div class="mt-2">Thêm NV mới</div>
                        </div>
                    </a>
                </div>
                <div class="col-auto">
                    <a asp-controller="AuditLog" asp-action="Index" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-journal-text fs-2 text-secondary"></i>
                            <div class="mt-2">Nhật ký hệ thống</div>
                        </div>
                    </a>
                </div>
            </div>
        }

        @if (isQuanLy || isBanHang)
        {
            <!-- Phần 2: Khách hàng (Quản lý + Bán hàng) -->
            <h5 class="mb-3"><i class="bi bi-person-heart me-2"></i>Quản lý Khách hàng</h5>
            <div class="row g-3 mb-4">
                <div class="col-auto">
                    <a asp-controller="KhachHang" asp-action="IndexKH" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-people fs-2 text-primary"></i>
                            <div class="mt-2">Danh sách KH</div>
                        </div>
                    </a>
                </div>
                <div class="col-auto">
                    <a asp-controller="KhachHang" asp-action="Create" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-person-plus fs-2 text-success"></i>
                            <div class="mt-2">Thêm KH mới</div>
                        </div>
                    </a>
                </div>
                <div class="col-auto">
                    <a asp-controller="LoaiKhachHang" asp-action="IndexLoaiKH" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-tags fs-2 text-info"></i>
                            <div class="mt-2">Loại khách hàng</div>
                        </div>
                    </a>
                </div>                
            </div>
        }

        @if (isQuanLy || isKhoHang)
        {
            <!-- Phần 3: Quản lý Nhà cung cấp  -->
            <h5 class="mb-3">Quản lý Nhà cung cấp</h5>

            <div class="row g-3 mb-4">
                <div class="col-auto">
                    <a asp-controller="NhaCungCap" asp-action="IndexNCC"
                       class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="min-width:120px;">
                            <i class="bi bi-truck fs-2 text-warning"></i>
                            <div class="mt-2">Nhà cung cấp</div>
                        </div>
                    </a>
                </div>
            </div>
        }


        @if (isQuanLy || isKhoHang)
        {
            <!-- Phần 3: Sản phẩm (Quản lý + Kho hàng) -->
            <h5 class="mb-3"><i class="bi bi-box-seam me-2"></i>Quản lý Sản phẩm</h5>
            <div class="row g-3 mb-4">
                <div class="col-auto">
                    <a asp-controller="SanPham" asp-action="IndexSP" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-box fs-2 text-primary"></i>
                            <div class="mt-2">Danh sách SP</div>
                        </div>
                    </a>
                </div>
               @*  <div class="col-auto">
                    <a asp-controller="SanPham" asp-action="Create" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-plus-square fs-2 text-success"></i>
                            <div class="mt-2">Thêm SP mới</div>
                        </div>
                    </a>
                </div> *@
                <div class="col-auto">
                    <a asp-controller="LoaiSanPham" asp-action="IndexLSP" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-tags fs-2 text-info"></i>
                            <div class="mt-2">Loại sản phẩm</div>
                        </div>
                    </a>
                </div>
            </div>
        }

        <!-- Phần 4: Đơn hàng (Tất cả vai trò, nhưng quyền khác nhau) -->
        <h5 class="mb-3"><i class="bi bi-cart me-2"></i>Quản lý Đơn hàng</h5>
        <div class="row g-3 mb-4">
            <div class="col-auto">
                <a asp-controller="DonHang" asp-action="IndexDH" class="text-decoration-none text-dark">
                    <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                        <i class="bi bi-receipt fs-2 text-primary"></i>
                        <div class="mt-2">
                            @if (isQuanLy)
                            {
                                <span>Tất cả đơn hàng</span>
                            }
                            else
                            {
                                <span>Đơn hàng của tôi</span>
                            }
                        </div>
                    </div>
                </a>
            </div>
            
            @if (isQuanLy || isBanHang)
            {
                <div class="col-auto">
                    <a asp-controller="DonHang" asp-action="Create" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-plus-circle fs-2 text-success"></i>
                            <div class="mt-2">Tạo đơn mới</div>
                        </div>
                    </a>
                </div>
            }

            @if (isQuanLy || isKhoHang)
            {
                <div class="col-auto">
                    <a asp-controller="DonHangChuaHoanThanh" asp-action="Index" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-clock-history fs-2 text-warning"></i>
                            <div class="mt-2">Đơn chưa xong</div>
                        </div>
                    </a>
                </div>
            }
            
            <div class="col-auto">
                <a asp-controller="ChiTietDonHang" asp-action="IndexCTDH" class="text-decoration-none text-dark">
                    <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                        <i class="bi bi-list-check fs-2 text-info"></i>
                        <div class="mt-2">Chi tiết đơn hàng</div>
                    </div>
                </a>
            </div>
        </div>

        @if (isQuanLy || isBanHang)
        {
            <!-- Phần 5: Hóa đơn (Quản lý + Bán hàng) -->
            <h5 class="mb-3"><i class="bi bi-file-earmark-ruled me-2"></i>Hóa đơn</h5>
            <div class="row g-3 mb-4">
                <div class="col-auto">
                    <a asp-controller="HoaDon" asp-action="IndexHD" class="text-decoration-none text-dark">
                        <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                            <i class="bi bi-receipt-cutoff fs-2 text-primary"></i>
                            <div class="mt-2">Danh sách HĐ</div>
                        </div>
                    </a>
                </div>
                @if (isQuanLy)
                {
                    <div class="col-auto">
                        <a asp-controller="HoaDon" asp-action="Create" class="text-decoration-none text-dark">
                            <div class="card text-center p-3 h-100 shadow-sm" style="cursor:pointer; min-width:120px;">
                                <i class="bi bi-file-earmark-plus fs-2 text-success"></i>
                                <div class="mt-2">Tạo HĐ mới</div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }

        <!-- Thông tin quyền hạn -->
        <div class="card mt-4 border-info">
            <div class="card-header bg-info text-white">
                <i class="bi bi-info-circle me-2"></i>Quyền hạn của bạn
            </div>
            <div class="card-body">
                @if (isQuanLy)
                {
                    <p class="mb-1"><i class="bi bi-check-circle text-success me-2"></i><strong>Quản lý:</strong> Bạn có toàn quyền trên hệ thống</p>
                    <ul class="mb-0 small">
                        <li>Quản lý nhân viên</li>
                        <li>Quản lý khách hàng, sản phẩm, nhà cung cấp</li>
                        <li>Xem và quản lý tất cả đơn hàng</li>
                        <li>Quản lý hóa đơn</li>
                        <li>Xem nhật ký hệ thống</li>
                    </ul>
                }
                else if (isBanHang)
                {
                    <p class="mb-1"><i class="bi bi-check-circle text-warning me-2"></i><strong>Bán hàng:</strong> Quyền hạn của bạn</p>
                    <ul class="mb-0 small">
                        <li>Quản lý khách hàng</li>
                        <li>Tạo và quản lý đơn hàng <strong>của mình</strong></li>
                        <li>Chỉnh sửa hóa đơn (không xóa)</li>
                        <li class="text-danger"><i class="bi bi-x-circle me-1"></i>Không có quyền quản lý sản phẩm</li>
                        <li class="text-danger"><i class="bi bi-x-circle me-1"></i>Không có quyền quản lý nhân viên</li>
                    </ul>
                }
                else if (isKhoHang)
                {
                    <p class="mb-1"><i class="bi bi-check-circle text-info me-2"></i><strong>Kho hàng:</strong> Quyền hạn của bạn</p>
                    <ul class="mb-0 small">
                        <li>Quản lý sản phẩm, loại sản phẩm, nhà cung cấp</li>
                        <li>Cập nhật trạng thái đơn hàng (Đang giao, Đã hủy)</li>
                        <li class="text-danger"><i class="bi bi-x-circle me-1"></i>Không có quyền quản lý khách hàng</li>
                        <li class="text-danger"><i class="bi bi-x-circle me-1"></i>Không có quyền tạo đơn hàng</li>
                        <li class="text-danger"><i class="bi bi-x-circle me-1"></i>Không có quyền quản lý hóa đơn</li>
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal xác nhận đăng xuất -->
<div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="logoutModalLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Xác nhận đăng xuất
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn đăng xuất khỏi hệ thống?</p>
                <small class="text-muted">Phiên làm việc của bạn sẽ kết thúc.</small>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <a href="@Url.Action("Logout", "Account")" class="btn btn-danger">
                    <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Modal Đổi mật khẩu -->
<div class="modal fade" id="changePassModal" tabindex="-1" aria-labelledby="changePassModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg rounded-3">
            <div class="modal-header bg-warning">
                <h5 class="modal-title fw-bold" id="changePassModalLabel">
                    <i class="bi bi-key me-2"></i>Đổi mật khẩu
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="ChangePassLogged" method="post" asp-controller="Account">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input asp-for="MatkhauMoi" class="form-control" type="password" placeholder="Nhập mật khẩu mới" />
                        <span asp-validation-for="MatkhauMoi" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <input asp-for="NhapLaiMatkhauMoi" class="form-control" type="password" placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="NhapLaiMatkhauMoi" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-info small py-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Mật khẩu phải có ít nhất 8 ký tự, bao gồm chữ hoa, chữ thường, số và ký tự đặc biệt.
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-semibold">
                        <i class="bi bi-check-lg me-1"></i>Cập nhật mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
