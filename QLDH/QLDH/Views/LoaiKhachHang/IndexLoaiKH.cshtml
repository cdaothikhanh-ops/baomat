@model List<QLDH.Models.LoaiKhachHang>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@{
    ViewData["Title"] = "Danh sách loại khách hàng";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}
<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>

<div class="container-fluid" style="margin-top:70px;">

    <div class="container mt-4">
        <div class="d-flex justify-content-between mb-3">
            <h4>Danh sách loại khách hàng</h4>
            <a asp-action="CreateLoaiKH" class="btn btn-primary">+ Thêm mới</a>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-striped table-bordered border-secondary-subtle mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th style="width:60px;">STT</th>
                            <th>Mã</th>
                            <th>Tên loại</th>
                            <th style="width:160px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var item = Model[i];
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@item.MALOAIKH</td>
                                <td>@item.TENLOAIKH</td>
                                <td>
                                    <a asp-action="EditLoaiKH" asp-route-id="@item.MALOAIKH" class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <form asp-action="DeleteLoaiKH" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc muốn xóa loại khách hàng này không?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="MALOAIKH" value="@item.MALOAIKH" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
