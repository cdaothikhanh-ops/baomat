@model QLDH.Models.DonHang
@using QLDH.Authorization

@{
    ViewData["Title"] = "Sửa Đơn hàng";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
    
    var vaiTro = Context.Session.GetString("VaiTro") ?? "";
    bool isQuanLy = vaiTro == Roles.QuanLy;
    bool isBanHang = vaiTro == Roles.BanHang;
    bool isKhoHang = vaiTro == Roles.KhoHang;
    
    // Các trạng thái được phép thay đổi theo role
    var allowedStatuses = ViewBag.AllowedStatuses as List<string> ?? new List<string>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
        <span class="ms-3">
            <span class="badge @(isQuanLy ? "bg-success" : isBanHang ? "bg-warning text-dark" : "bg-info")">
                @vaiTro
            </span>
        </span>
    </div>

    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">
            <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
        </a>
    </div>
</div>

<div class="container" style="margin-top:70px; max-width:800px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Cập nhật Đơn hàng</h4>
        </div>
        <div class="card-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="MADH" />

                <div class="row g-3">
                    <!-- Mã đơn hàng -->
                    <div class="col-md-6">
                        <label asp-for="MADH" class="form-label">Mã đơn hàng</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-hash"></i></span>
                            <input asp-for="MADH" class="form-control" readonly />
                        </div>
                    </div>

                    <!-- Ngày lập -->
                    <div class="col-md-6">
                        <label asp-for="NGAYLAP" class="form-label">Ngày lập</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                            @if (isQuanLy)
                            {
                                <input asp-for="NGAYLAP" class="form-control" type="date" />
                            }
                            else
                            {
                                <input asp-for="NGAYLAP" class="form-control" type="date" readonly />
                            }
                        </div>
                    </div>

                    <!-- Khách hàng -->
                    <div class="col-md-6">
                        <label asp-for="MAKH" class="form-label">Khách hàng</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            @if (isQuanLy || isBanHang)
                            {
                                <select asp-for="MAKH" class="form-select"
                                        asp-items="@(new SelectList(ViewBag.KhachHangList, "MAKH", "TENKH", Model.MAKH))">
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control" 
                                       value="@(ViewBag.TenKH ?? Model.MAKH)" readonly />
                                <input type="hidden" asp-for="MAKH" />
                            }
                        </div>
                    </div>

                    <!-- Nhân viên -->
                    <div class="col-md-6">
                        <label asp-for="MANV" class="form-label">Nhân viên phụ trách</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person-badge"></i></span>
                            @if (isQuanLy)
                            {
                                <select asp-for="MANV" class="form-select"
                                        asp-items="@(new SelectList(ViewBag.NhanVienList, "MANV", "TENNV", Model.MANV))">
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control" 
                                       value="@(ViewBag.TenNV ?? Model.MANV)" readonly />
                                <input type="hidden" asp-for="MANV" />
                            }
                        </div>
                    </div>

                    <!-- Trạng thái đơn hàng -->
                    <div class="col-md-12">
                        <label asp-for="TRANGTHAI" class="form-label">
                            Trạng thái đơn hàng
                            @if (isKhoHang)
                            {
                                <small class="text-muted">(Kho hàng chỉ được cập nhật trạng thái)</small>
                            }
                        </label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-info-circle"></i></span>
                            @if (allowedStatuses.Any())
                            {
                                <select asp-for="TRANGTHAI" class="form-select">
                                    @foreach (var status in allowedStatuses)
                                    {
                                        var statusClass = status switch
                                        {
                                            "Chờ xử lý" => "text-warning",
                                            "Đang giao" => "text-primary",
                                            "Đã hoàn thành" => "text-success",
                                            "Đã hủy" => "text-danger",
                                            _ => ""
                                        };
                                        <option value="@status" selected="@(Model.TRANGTHAI == status)">
                                            @status
                                        </option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control" value="@Model.TRANGTHAI" readonly />
                                <input type="hidden" asp-for="TRANGTHAI" />
                            }
                        </div>
                        
                        <!-- Hiện trạng thái hiện tại với màu -->
                        <div class="mt-2">
                            <span class="small text-muted">Trạng thái hiện tại: </span>
                            @{
                                var currentStatusBadge = Model.TRANGTHAI switch
                                {
                                    "Chờ xử lý" => "bg-warning text-dark",
                                    "Đang giao" => "bg-primary",
                                    "Đã hoàn thành" => "bg-success",
                                    "Đã hủy" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @currentStatusBadge">@Model.TRANGTHAI</span>
                        </div>
                    </div>

                    <!-- Thông tin quyền hạn -->
                    <div class="col-12">
                        <div class="alert @(isQuanLy ? "alert-success" : isKhoHang ? "alert-info" : "alert-warning") small py-2">
                            <i class="bi bi-info-circle me-1"></i>
                            @if (isQuanLy)
                            {
                                <span>Bạn có quyền chỉnh sửa tất cả thông tin đơn hàng.</span>
                            }
                            else if (isBanHang)
                            {
                                <span>Bạn có thể thay đổi khách hàng và trạng thái (Chờ xử lý → Đã hủy nếu cần).</span>
                            }
                            else if (isKhoHang)
                            {
                                <span>Bạn chỉ có thể cập nhật trạng thái đơn hàng (Đang giao / Đã hủy).</span>
                            }
                        </div>
                    </div>
                </div>

                <hr />

                <div class="d-flex justify-content-between">
                    <a asp-action="IndexDH" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại
                    </a>
                    <div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Lưu thay đổi
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal xác nhận đăng xuất -->
<div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="logoutModalLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Xác nhận đăng xuất
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                Bạn có muốn đăng xuất?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <a href="@Url.Action("Logout", "Account")" class="btn btn-danger">
                    <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
