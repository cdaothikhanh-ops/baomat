@model IEnumerable<QLDH.Models.DonHang>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@{
    ViewData["Title"] = "Danh sách Đơn hàng";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH + Xin chào -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Bên phải: nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>


<div class="container-fluid" style="margin-top:70px;">

<h2>Danh sách Đơn hàng</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Thêm mới</a>
</p>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>Mã đơn hàng</th>
            <th>Ngày lập</th>
            <th>Ngày hoàn thành</th>
            <th>Trạng thái</th>
            <th>Tên khách hàng</th>
            <th>Tên nhân viên</th>
            <th>Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var dh in Model)
        {
            <tr>
                <td>@dh.MADH</td>
                <td>@dh.NGAYLAP.ToShortDateString()</td>
                <td>@dh.NGAYHT?.ToShortDateString()</td>
                <td>@dh.TRANGTHAI</td>
                <td>@dh.KhachHang?.TENKH</td>
                <td>@dh.NhanVien?.TENNV</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@dh.MADH" class="btn btn-sm btn-primary">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                        <button class="btn btn-sm btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@dh.MADH"
                                data-name="@dh.MADH">
                            <i class="bi bi-trash"></i>
                        </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Modal Delete -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xác nhận xoá</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
             <div class="modal-body">
                    Bạn có chắc muốn xoá đơn hàng <strong id="dhName"></strong>?
                </div>
            <div class="modal-footer">
                <form method="post" asp-action="Delete" asp-controller="DonHang">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="dhId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xoá</button>
                </form>
            </div>
        </div>
    </div>
</div>

    <!-- Modal xác nhận đăng xuất -->
    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="logoutModalLabel">Xác nhận</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    Bạn có muốn đăng xuất?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                    <a href="/Account/Logout" class="btn btn-danger">Đăng xuất</a>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
                    var deleteModal = document.getElementById('deleteModal');
            deleteModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;

                var id = button.getAttribute('data-id');
                var name = button.getAttribute('data-name');

                deleteModal.querySelector('#dhName').textContent = name;
                deleteModal.querySelector('#dhId').value = id;            
            });
    </script>
}
