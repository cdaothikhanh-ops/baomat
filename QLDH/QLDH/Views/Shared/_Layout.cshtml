<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QLDH</title>

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QLDH.styles.css" asp-append-version="true" />
</head>
<body>
    @* Xác định có hiển thị header hay không *@
    @{
        var showHeader = ViewData["ShowHeader"] != null ? (bool)ViewData["ShowHeader"] : true;
    }

    @if (showHeader)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <!-- Logo / Tên app -->
                    <a class="navbar-brand fw-bold text-white" asp-area="" asp-controller="Home" asp-action="Index">QLDH</a>

                    <!-- Nút thu gọn menu khi màn hình nhỏ -->
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <!-- Menu trái và nút bên phải -->
                    <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>
                        </ul>
                        <div class="d-flex">
                            @if (User.Identity.IsAuthenticated)  // Nếu đã đăng nhập
                            {
                                <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                                    <button type="submit" class="btn btn-outline-light">Đăng xuất</button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-light me-2" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                                <a class="btn btn-outline-light" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            }
                        </div>

                    </div>
                </div>
            </nav>
        </header>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @{
        var showFooter = true;
        if (ViewData["ShowFooter"] != null)
        {
            showFooter = (bool)ViewData["ShowFooter"];
        }
    }

    @if (showFooter)
    {
        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2025 - QLDH - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    }


    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
