@model IEnumerable<QLDH.Models.HoaDon>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@{
    ViewData["Title"] = "Danh sách Hóa đơn";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH + Xin chào -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Bên phải: nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>


<div class="container-fluid" style="margin-top:70px;">

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Thêm mới</a>
</p>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>Mã Hóa đơn</th>
            <th>Mã Đơn hàng</th>
            <th>Ngày lập</th>
            <th>Phương thức TT</th>
            <th>Tổng tiền</th>
            <th>Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var hd in Model)
        {
            <tr>
                <td>@hd.MAHD</td>
                <td>@hd.MADH</td>
                <td>@hd.NGAYLAP.ToShortDateString()</td>
                <td>@hd.PHUONGTHUCTT</td>
                <td>@hd.TONGTIEN.ToString("N0")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@hd.MAHD" class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil-square"></i> Sửa
                    </a>

                    <button class="btn btn-sm btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteHDModal"
                            data-id="@hd.MAHD"
                            data-name="@hd.MAHD">
                        <i class="bi bi-trash"></i> Xóa
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Modal Delete Hóa đơn -->
<div class="modal fade" id="deleteHDModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xác nhận xóa Hóa đơn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc muốn xóa hóa đơn <strong id="hdName"></strong>?
            </div>
            <div class="modal-footer">
                <form method="post" asp-action="Delete" asp-controller="HoaDon">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="hdId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">Xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>
</div>>

@section Scripts {
    <script>
        var deleteHDModal = document.getElementById('deleteHDModal');
        deleteHDModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;

            var id = button.getAttribute('data-id');
            var name = button.getAttribute('data-name');

            deleteHDModal.querySelector('#hdName').textContent = name;
            deleteHDModal.querySelector('#hdId').value = id;
        });
    </script>
}
