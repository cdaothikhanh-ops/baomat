@model QLDH.Models.ChiTietDonHang

@{
    ViewData["Title"] = "Tạo Chi tiết đơn hàngg";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Bên trái: QLDH + Xin chào -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Bên phải: nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>

<div class="container-fluid" style="margin-top:70px;">

<h2>Tạo Chi tiết đơn hàng</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- Mã Đơn hàng -->
    <div class="form-group">
        <label>Mã Đơn hàng</label>
        <select asp-for="MADH" class="form-control" required>
            <option value="">-- Chọn Đơn hàng --</option>
            @foreach (var dh in ViewBag.DonHangList as List<QLDH.Models.DonHang>)
            {
                <option value="@dh.MADH">@dh.MADH</option>
            }
        </select>
    </div>

    <!-- Sản phẩm -->
    <div class="form-group">
        <label>Tên Sản phẩm</label>
        <select id="MASP" asp-for="MASP" class="form-control" required>
            <option value="">-- Chọn sản phẩm --</option>
            @foreach (var sp in ViewBag.SanPhamList as List<QLDH.Models.SanPham>)
            {
                <option value="@sp.MASP" data-price="@sp.GIABAN">@sp.TENSP</option>
            }
        </select>
    </div>

    <!-- Số lượng -->
    <div class="form-group">
        <label>Số lượng</label>
        <input asp-for="SOLUONG" class="form-control" required />
    </div>

    <!-- Đơn giá (readonly, tự fill theo MASP) -->
    <div class="form-group">
        <label>Đơn giá</label>
        <input id="DONGIA" asp-for="DONGIA" class="form-control" readonly />
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-action="IndexCTDH" class="btn btn-secondary">Hủy</a>
    </div>

</form>

<!-- Modal xác nhận đăng xuất -->
<div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="logoutModalLabel">Xác nhận</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                Bạn có muốn đăng xuất?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huỷ</button>
                <a href="/Account/Logout" class="btn btn-danger">Đăng xuất</a>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Khi chọn sản phẩm, tự fill DONGIA
        document.getElementById("MASP").addEventListener("change", function () {
            var selected = this.options[this.selectedIndex];
            var price = selected.getAttribute("data-price");
            document.getElementById("DONGIA").value = price || '';
        });
    </script>
}
