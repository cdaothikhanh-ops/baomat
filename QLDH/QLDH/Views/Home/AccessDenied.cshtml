@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Truy cập bị từ chối
                    </h4>
                </div>
                <div class="card-body text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-shield-lock-fill text-danger" style="font-size: 5rem;"></i>
                    </div>
                    
                    <h3 class="text-danger mb-3">Bạn không có quyền truy cập!</h3>
                    
                    <p class="text-muted mb-4">
                        Tài khoản của bạn không có quyền thực hiện thao tác này.<br/>
                        Vui lòng liên hệ quản trị viên nếu bạn cần quyền truy cập.
                    </p>

                    @if (!string.IsNullOrEmpty(ViewBag.MaNV))
                    {
                        <div class="alert alert-secondary d-inline-block">
                            <strong>Tài khoản:</strong> @ViewBag.MaNV<br/>
                            <strong>Vai trò:</strong> 
                            <span class="badge @(ViewBag.VaiTro == "Quản lý" ? "bg-success" : 
                                                  ViewBag.VaiTro == "Bán hàng" ? "bg-primary" : "bg-info")">
                                @ViewBag.VaiTro
                            </span>
                        </div>
                    }

                    <div class="mt-4">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-primary me-2">
                            <i class="bi bi-house-fill me-1"></i>Trang chủ
                        </a>
                        <button onclick="history.back()" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại
                        </button>
                    </div>
                </div>
                
                <div class="card-footer bg-light">
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        Nếu bạn cho rằng đây là lỗi, vui lòng liên hệ bộ phận IT.
                    </small>
                </div>
            </div>

            <!-- Thông tin quyền của từng vai trò -->
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-key-fill me-2"></i>
                        Phân quyền theo vai trò
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <h6 class="text-success"><i class="bi bi-person-badge me-1"></i>Quản lý</h6>
                            <ul class="small">
                                <li>Toàn quyền hệ thống</li>
                                <li>Quản lý nhân viên</li>
                                <li>Xem tất cả đơn hàng</li>
                                <li>Quản lý khách hàng</li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <h6 class="text-primary"><i class="bi bi-cart me-1"></i>Bán hàng</h6>
                            <ul class="small">
                                <li>Tạo và xử lý đơn hàng</li>
                                <li>Xem đơn hàng của mình</li>
                                <li>Xem thông tin khách hàng</li>
                                <li>Cập nhật trạng thái đơn</li>
                            </ul>
                        </div>
                        <div class="col-md-4">
                            <h6 class="text-info"><i class="bi bi-box-seam me-1"></i>Kho hàng</h6>
                            <ul class="small">
                                <li>Quản lý kho sản phẩm</li>
                                <li>Xem đơn hàng cần giao</li>
                                <li>Cập nhật trạng thái giao</li>
                                <li>Xem thông tin cá nhân</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
