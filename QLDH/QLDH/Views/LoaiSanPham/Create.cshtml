@model QLDH.Models.LoaiSanPham

@{
    ViewData["Title"] = "Thêm Loại sản phẩm";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<!-- Topbar -->
<div class="topbar" style="
    position:fixed;
    top:0;
    left:0;
    right:0;
    height:50px;
    background-color:#0d6efd;
    color:white;
    z-index:1000;
    display:flex;
    align-items:center;
    padding:0 16px;
">
    <!-- Logo QLDH -->
    <div class="d-flex align-items-center">
        <a href="@Url.Action("Dashboard", "Account")" style="color:white; text-decoration:none;">
            <strong class="me-2">QLDH</strong>
        </a>
    </div>

    <!-- Nút Đăng xuất -->
    <div class="d-flex align-items-center ms-auto">
        <a class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#logoutModal">Đăng xuất</a>
    </div>
</div>

<div class="container-fluid" style="margin-top:70px;">
    <h2 class="text-primary mb-3">Thêm Loại sản phẩm</h2>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="MALOAISP" class="form-label">Mã loại</label>
            <input asp-for="MALOAISP" class="form-control" readonly />
            <span asp-validation-for="MALOAISP" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="TENLOAI" class="form-label">Tên loại</label>
            <input asp-for="TENLOAI" class="form-control" />
            <span asp-validation-for="TENLOAI" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-action="IndexLSP" class="btn btn-secondary">Hủy</a>
    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
