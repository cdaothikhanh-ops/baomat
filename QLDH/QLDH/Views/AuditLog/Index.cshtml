@model List<QLDH.Models.AuditLog>
@{
    ViewData["Title"] = "Nhật ký Hệ thống";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["ShowHeader"] = false;
    ViewData["ShowFooter"] = false;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-journal-text text-primary me-2"></i>Nhật ký Hệ thống
            </h2>
            <p class="text-muted mb-0">Theo dõi tất cả hoạt động trong hệ thống</p>
        </div>
        <div>            
            <a asp-action="ExportCsv" asp-route-searchTerm="@ViewBag.SearchTerm" 
               asp-route-filterAction="@ViewBag.FilterAction" asp-route-filterEntity="@ViewBag.FilterEntity"
               asp-route-fromDate="@ViewBag.FromDate" asp-route-toDate="@ViewBag.ToDate"
               class="btn btn-success">
                <i class="bi bi-download me-1"></i>Xuất CSV
            </a>
        </div>
    </div>

    <!-- Thông báo -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle me-2"></i>@TempData["InfoMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Bộ lọc -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <i class="bi bi-funnel me-2"></i>Bộ lọc tìm kiếm
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small">Từ khóa</label>
                    <input type="text" name="searchTerm" class="form-control" 
                           value="@ViewBag.SearchTerm" placeholder="Tìm theo tên, ID...">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Hành động</label>
                    <select name="filterAction" class="form-select">
                        <option value="">-- Tất cả --</option>
                        @if (ViewBag.DistinctActions != null)
                        {
                            foreach (var action in ViewBag.DistinctActions)
                            {
                                <option value="@action" selected="@(ViewBag.FilterAction == action)">@action</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Đối tượng</label>
                    <select name="filterEntity" class="form-select">
                        <option value="">-- Tất cả --</option>
                        @if (ViewBag.DistinctEntities != null)
                        {
                            foreach (var entity in ViewBag.DistinctEntities)
                            {
                                <option value="@entity" selected="@(ViewBag.FilterEntity == entity)">@entity</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Từ ngày</label>
                    <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Đến ngày</label>
                    <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate">
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Kết quả -->
    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <span>
                <strong>@ViewBag.TotalItems</strong> bản ghi
                @if (ViewBag.TotalPages > 1)
                {
                    <span class="text-muted">(Trang @ViewBag.CurrentPage / @ViewBag.TotalPages)</span>
                }
            </span>
            <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#clearLogsModal">
                <i class="bi bi-trash me-1"></i>Xóa log cũ
            </button>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width:50px">#</th>
                                <th style="width:150px">Thời gian</th>
                                <th style="width:120px">Người dùng</th>
                                <th style="width:100px">Hành động</th>
                                <th style="width:120px">Đối tượng</th>
                                <th style="width:100px">ID</th>
                                <th>Mô tả</th>
                                <th style="width:120px">IP</th>
                                <th style="width:60px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                var actionBadgeClass = log.Action switch
                                {
                                    "Create" => "bg-success",
                                    "Update" => "bg-warning text-dark",
                                    "Delete" => "bg-danger",
                                    "Login" => "bg-primary",
                                    "Logout" => "bg-secondary",
                                    "View" => "bg-info",
                                    "Export" => "bg-dark",
                                    _ => "bg-secondary"
                                };
                                
                                var actionIcon = log.Action switch
                                {
                                    "Create" => "bi-plus-circle",
                                    "Update" => "bi-pencil",
                                    "Delete" => "bi-trash",
                                    "Login" => "bi-box-arrow-in-right",
                                    "Logout" => "bi-box-arrow-right",
                                    "View" => "bi-eye",
                                    "Export" => "bi-download",
                                    _ => "bi-activity"
                                };
                                
                                <tr>
                                    <td class="text-muted small">@log.Id</td>
                                    <td class="small">
                                        <span title="@log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")">
                                            @log.Timestamp.ToString("dd/MM HH:mm")
                                        </span>
                                    </td>
                                    <td>
                                        <i class="bi bi-person text-muted me-1"></i>
                                        <span class="small">@log.UserName</span>
                                    </td>
                                    <td>
                                        <span class="badge @actionBadgeClass">
                                            <i class="bi @actionIcon me-1"></i>@log.Action
                                        </span>
                                    </td>
                                    <td class="small">@log.EntityType</td>
                                    <td class="small font-monospace">@log.EntityId</td>
                                    <td class="small text-truncate" style="max-width:200px" title="@log.Description">
                                        @log.Description
                                    </td>
                                    <td class="small font-monospace">@log.IpAddress</td>
                                    <td class="text-nowrap">
                                        <a asp-action="Details" asp-route-id="@log.Id" class="btn btn-sm btn-outline-primary" title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if ((log.Action == "DELETE" || log.Action == "UPDATE") && !string.IsNullOrEmpty(log.OldValues))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-success" 
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#restoreModal"
                                                    data-log-id="@log.Id"
                                                    data-action="@log.Action"
                                                    data-entity="@log.EntityType"
                                                    data-entity-id="@log.EntityId"
                                                    title="Phục hồi dữ liệu">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size:3rem"></i>
                    <p class="text-muted mt-3">Không có bản ghi nào</p>
                </div>
            }
        </div>

        <!-- Phân trang -->
        @if (ViewBag.TotalPages > 1)
        {
            <div class="card-footer bg-white">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        @{
                            var currentPage = (int)ViewBag.CurrentPage;
                            var totalPages = (int)ViewBag.TotalPages;
                            var startPage = Math.Max(1, currentPage - 2);
                            var endPage = Math.Min(totalPages, currentPage + 2);
                        }

                        @if (currentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="1"
                                   asp-route-searchTerm="@ViewBag.SearchTerm"
                                   asp-route-filterAction="@ViewBag.FilterAction"
                                   asp-route-filterEntity="@ViewBag.FilterEntity"
                                   asp-route-fromDate="@ViewBag.FromDate"
                                   asp-route-toDate="@ViewBag.ToDate">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@(currentPage - 1)"
                                   asp-route-searchTerm="@ViewBag.SearchTerm"
                                   asp-route-filterAction="@ViewBag.FilterAction"
                                   asp-route-filterEntity="@ViewBag.FilterEntity"
                                   asp-route-fromDate="@ViewBag.FromDate"
                                   asp-route-toDate="@ViewBag.ToDate">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@i"
                                   asp-route-searchTerm="@ViewBag.SearchTerm"
                                   asp-route-filterAction="@ViewBag.FilterAction"
                                   asp-route-filterEntity="@ViewBag.FilterEntity"
                                   asp-route-fromDate="@ViewBag.FromDate"
                                   asp-route-toDate="@ViewBag.ToDate">
                                    @i
                                </a>
                            </li>
                        }

                        @if (currentPage < totalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@(currentPage + 1)"
                                   asp-route-searchTerm="@ViewBag.SearchTerm"
                                   asp-route-filterAction="@ViewBag.FilterAction"
                                   asp-route-filterEntity="@ViewBag.FilterEntity"
                                   asp-route-fromDate="@ViewBag.FromDate"
                                   asp-route-toDate="@ViewBag.ToDate">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@totalPages"
                                   asp-route-searchTerm="@ViewBag.SearchTerm"
                                   asp-route-filterAction="@ViewBag.FilterAction"
                                   asp-route-filterEntity="@ViewBag.FilterEntity"
                                   asp-route-fromDate="@ViewBag.FromDate"
                                   asp-route-toDate="@ViewBag.ToDate">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>

    <!-- Quay về -->
    <div class="mt-3">
        <a asp-controller="Account" asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Về Dashboard
        </a>
    </div>
</div>

<!-- Modal xóa log cũ -->
<div class="modal fade" id="clearLogsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>Xóa log cũ
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ClearOldLogs" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p>Bạn muốn giữ lại log trong bao nhiêu ngày gần đây?</p>
                    <div class="mb-3">
                        <label class="form-label">Số ngày giữ lại:</label>
                        <select name="daysToKeep" class="form-select">
                            <option value="30">30 ngày</option>
                            <option value="60">60 ngày</option>
                            <option value="90" selected>90 ngày</option>
                            <option value="180">180 ngày</option>
                            <option value="365">365 ngày</option>
                        </select>
                    </div>
                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Các bản ghi cũ hơn số ngày được chọn sẽ bị xóa vĩnh viễn!
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Xóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal phục hồi dữ liệu -->
<div class="modal fade" id="restoreModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>Phục hồi dữ liệu
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RestoreData" method="post" id="restoreForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="logId" id="restoreLogId" />
                <div class="modal-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong id="restoreAction"></strong>: <span id="restoreEntity"></span>
                        <br />
                        <small>ID: <code id="restoreEntityId"></code></small>
                    </div>
                    <p id="restoreMessage" class="mb-0"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Phục hồi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Script cho modal phục hồi
    document.addEventListener('DOMContentLoaded', function() {
        var restoreModal = document.getElementById('restoreModal');
        if (restoreModal) {
            restoreModal.addEventListener('show.bs.modal', function(event) {
                var button = event.relatedTarget;
                var logId = button.getAttribute('data-log-id');
                var action = button.getAttribute('data-action');
                var entity = button.getAttribute('data-entity');
                var entityId = button.getAttribute('data-entity-id');
                
                document.getElementById('restoreLogId').value = logId;
                document.getElementById('restoreAction').textContent = action === 'DELETE' ? 'Khôi phục bản ghi đã xóa' : 'Hoàn tác thay đổi';
                document.getElementById('restoreEntity').textContent = entity;
                document.getElementById('restoreEntityId').textContent = entityId;
                
                if (action === 'DELETE') {
                    document.getElementById('restoreMessage').innerHTML = 
                        '<i class="bi bi-info-circle text-info me-1"></i>Dữ liệu đã xóa sẽ được khôi phục lại bảng <strong>' + entity + '</strong>.';
                } else {
                    document.getElementById('restoreMessage').innerHTML = 
                        '<i class="bi bi-info-circle text-warning me-1"></i>Dữ liệu sẽ được khôi phục về trạng thái trước khi sửa.';
                }
            });
        }
    });
</script>
